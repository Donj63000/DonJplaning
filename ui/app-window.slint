component TeamMemberListItem inherits Rectangle {
    in property <TeamMemberRowData> member_row;
    callback remove(string);

    min-height: 44px;
    border-radius: 12px;
    border-width: 1px;
    border-color: #dde5dd;
    background: #fbfcfb;

    HorizontalBox {
        padding: 10px;
        spacing: 8px;

        VerticalBox {
            alignment: center;
            spacing: 0px;
            horizontal-stretch: 1;

            Text {
                text: root.member_row.worker_name;
                color: #183027;
                font-size: 12px;
                font-weight: 700;
                wrap: word-wrap;
            }

            Text {
                text: root.member_row.role_label;
                color: #6b7c72;
                font-size: 11px;
            }
        }

        Button {
            text: "Retirer";
            clicked => { root.remove(root.member_row.worker_id); }
        }
    }
}

component PlanningShiftCell inherits FocusScope {
    in property <PlanningCellData> cell;
    callback activated(int);

    min-width: 72px;
    preferred-width: 72px;
    max-width: 72px;
    min-height: 62px;
    preferred-height: 62px;
    max-height: 62px;
    accessible-role: button;
    accessible-label: cell.label == "" ? "Cellule vide" : cell.label;
    accessible-description: cell.time_range;
    accessible-action-default => { root.activated(root.cell.day_offset); }

    pure function background_for(token: string) -> brush {
        if (token == "night-blue") { return #4c6f93; }
        if (token == "afternoon-red") { return #b85a54; }
        if (token == "morning-yellow") { return #d9bf65; }
        if (token == "day-beige") { return #d3c4a7; }
        if (token == "neutral-gray") { return #d0d7d1; }
        if (token == "off-gray") { return #d9dddd; }
        return #f8faf8;
    }

    pure function text_color_for(token: string) -> color {
        return token == "night-blue" || token == "afternoon-red" ? white : #1a2f26;
    }

    Rectangle {
        border-radius: 12px;
        border-width: root.has-focus || root.cell.is_manual ? 2px : 1px;
        border-color: root.has-focus ? #264538 : (root.cell.is_manual ? #4f755d : #d6dfd6);
        background: root.background_for(root.cell.style_token);
        width: parent.width;
        height: parent.height;

        VerticalBox {
            padding: 6px;
            spacing: 2px;
            alignment: center;

            Text {
                text: root.cell.short_code == "" ? "-" : root.cell.short_code;
                color: root.text_color_for(root.cell.style_token);
                font-size: 16px;
                font-weight: 800;
                horizontal-alignment: center;
                wrap: word-wrap;
            }

            Text {
                text: root.cell.is_manual ? (root.cell.is_manual_off ? "Manuel OFF" : "Manuel") : (root.cell.has_assignment ? "Auto" : "");
                color: root.text_color_for(root.cell.style_token);
                font-size: 10px;
                font-weight: 700;
                horizontal-alignment: center;
            }
        }
    }

    area := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.focus();
            root.activated(root.cell.day_offset);
        }
    }
}

export component AppWindow inherits Window {
    title: "DonJplaning";
    width: 1600px;
    height: 980px;
    background: #eef2ee;

    in property <[WorkerRowData]> worker_rows;
    in property <[ShiftSlotRowData]> shift_slot_rows;
    in property <[TeamRowData]> team_rows;
    in property <[TeamMemberRowData]> selected_team_member_rows;
    in property <[DayHeaderData]> day_headers;
    in property <[PlanningRowData]> planning_rows;

    in property <[string]> role_options;
    in property <[string]> shift_style_options;
    in property <[string]> active_state_options;
    in property <[string]> active_shift_slot_options;
    in property <[string]> team_member_role_options;
    in property <[string]> team_member_candidate_options;

    in-out property <int> current_page: 0;
    in-out property <string> status_message: "";
    in-out property <string> db_path_hint: "";

    in-out property <string> planning_start_date: "";
    in-out property <string> planning_days: "90";
    in-out property <string> selected_cell_worker_id: "";
    in-out property <string> selected_cell_date: "";
    in-out property <string> selected_cell_summary: "Aucune cellule selectionnee.";
    in-out property <int> manual_shift_index: -1;
    in-out property <int> summary_generated_assignments: 0;
    in-out property <int> summary_manual_overrides: 0;
    in-out property <int> summary_active_teams: 0;
    in-out property <int> summary_planned_workers: 0;

    in-out property <string> worker_form_id: "";
    in-out property <string> worker_last_name: "";
    in-out property <string> worker_first_name: "";
    in-out property <int> worker_role_index: -1;
    in-out property <bool> worker_existing: false;
    in-out property <string> new_role_name: "";

    in-out property <string> shift_slot_form_id: "";
    in-out property <string> shift_slot_name: "";
    in-out property <string> shift_slot_code: "";
    in-out property <string> shift_slot_start_hour: "";
    in-out property <string> shift_slot_start_minute: "";
    in-out property <string> shift_slot_end_hour: "";
    in-out property <string> shift_slot_end_minute: "";
    in-out property <int> shift_slot_style_index: 0;
    in-out property <int> shift_slot_active_index: 0;
    in-out property <bool> shift_slot_existing: false;
    in-out property <string> rotation_reference_week_start: "";
    in-out property <int> rotation_week_one_shift_index: 0;
    in-out property <int> rotation_week_two_shift_index: 1;
    in-out property <int> rotation_week_three_shift_index: 2;

    in-out property <string> team_form_id: "";
    in-out property <string> team_name: "";
    in-out property <int> team_anchor_shift_index: 0;
    in-out property <int> team_active_index: 0;
    in-out property <bool> team_existing: false;
    in-out property <int> team_member_worker_index: -1;
    in-out property <int> team_member_role_index: 1;

    out property <bool> has_selected_cell: selected_cell_worker_id != "" && selected_cell_date != "";
    out property <bool> can_generate_planning: !planning_start_date.is-empty && !planning_days.is-empty;
    out property <bool> can_save_manual_assignment: has_selected_cell && manual_shift_index >= 0;
    out property <bool> can_save_worker: !worker_last_name.is-empty && !worker_first_name.is-empty && worker_role_index >= 0;
    out property <bool> can_add_job_role: !new_role_name.is-empty;
    out property <bool> can_save_shift_slot:
        !shift_slot_name.is-empty
        && !shift_slot_code.is-empty
        && !shift_slot_start_hour.is-empty
        && !shift_slot_start_minute.is-empty
        && !shift_slot_end_hour.is-empty
        && !shift_slot_end_minute.is-empty
        && shift_slot_style_index >= 0
        && shift_slot_active_index >= 0;
    out property <bool> can_save_team: !team_name.is-empty && team_anchor_shift_index >= 0 && team_active_index >= 0;
    out property <bool> can_add_team_member: team_form_id != "" && team_member_worker_index >= 0 && team_member_role_index >= 0;

    callback select_page(int);

    callback generate_planning(string, string);
    callback select_planning_cell(string, int);
    callback save_manual_assignment(string, string, int);
    callback mark_manual_off(string, string);
    callback clear_manual_override(string, string);
    callback clear_planning_selection();

    callback select_worker(string);
    callback clear_worker_form();
    callback save_worker(string, string, string, int);
    callback add_job_role(string);
    callback delete_worker(string);

    callback select_shift_slot(string);
    callback clear_shift_slot_form();
    callback save_shift_slot(string, string, string, string, string, string, string, int, int);
    callback save_rotation_cycle(string, int, int, int);

    callback select_team(string);
    callback clear_team_form();
    callback save_team(string, string, int, int);
    callback add_team_member(string, int, int);
    callback remove_team_member(string, string);

    pure function page_title() -> string {
        if (current_page == 0) { return "Planning 3x8"; }
        if (current_page == 1) { return "Equipes"; }
        if (current_page == 2) { return "Plages horaires"; }
        return "Effectif";
    }

    pure function page_helper() -> string {
        if (current_page == 0) { return "Je genere le planning automatique puis je corrige au besoin cellule par cellule."; }
        if (current_page == 1) { return "Je garde une equipe par poste de reference, avec un chef d'equipe et un ou plusieurs operateurs."; }
        if (current_page == 2) { return "Je regle ici les horaires et le cycle hebdomadaire 13-21 / 5-13 / 21-5."; }
        return "Je maintiens ici la base salariée et les postes metier.";
    }

    HorizontalBox {
        spacing: 18px;
        padding: 18px;

        Rectangle {
            min-width: 228px;
            preferred-width: 228px;
            border-radius: 22px;
            border-width: 1px;
            border-color: #d6dfd6;
            background: #edf2ed;

            VerticalBox {
                padding: 18px;
                spacing: 16px;

                VerticalBox {
                    spacing: 4px;
                    Text { text: "DonJplaning"; color: #193028; font-size: 26px; font-weight: 700; }
                    Text { text: "Usine 3x8"; color: #65786d; font-size: 12px; }
                }

                SidebarButton {
                    label: "Planning";
                    active: root.current_page == 0;
                    clicked => { root.select_page(0); }
                }
                SidebarButton {
                    label: "Equipes";
                    active: root.current_page == 1;
                    clicked => { root.select_page(1); }
                }
                SidebarButton {
                    label: "Plages horaires";
                    active: root.current_page == 2;
                    clicked => { root.select_page(2); }
                }
                SidebarButton {
                    label: "Effectif";
                    active: root.current_page == 3;
                    clicked => { root.select_page(3); }
                }

                Rectangle { vertical-stretch: 1; background: transparent; }

                Rectangle {
                    min-height: 92px;
                    border-radius: 16px;
                    border-width: 1px;
                    border-color: #d6dfd6;
                    background: #f7f9f7;

                    VerticalBox {
                        padding: 12px;
                        spacing: 4px;

                        Text { text: "Base locale"; color: #244136; font-size: 12px; font-weight: 700; }
                        Text { text: root.db_path_hint; color: #6d7d73; wrap: word-wrap; font-size: 11px; }
                    }
                }
            }
        }

        Rectangle {
            horizontal-stretch: 1;
            border-radius: 24px;
            border-width: 1px;
            border-color: #d7dfd7;
            background: #f7f9f7;

            VerticalBox {
                padding: 20px;
                spacing: 16px;

                VerticalBox {
                    spacing: 4px;

                    Text {
                        text: root.page_title();
                        color: #193028;
                        font-size: 28px;
                        font-weight: 700;
                    }

                    Text {
                        text: root.page_helper();
                        color: #65786d;
                        font-size: 12px;
                        wrap: word-wrap;
                    }
                }

                if root.status_message != "" : Rectangle {
                    border-radius: 14px;
                    border-width: 1px;
                    border-color: #cad8cd;
                    background: #eef5ef;
                    min-height: 52px;

                    Text {
                        text: root.status_message;
                        color: #264538;
                        font-size: 12px;
                        wrap: word-wrap;
                        vertical-alignment: center;
                        width: parent.width - 24px;
                        height: parent.height;
                        x: 12px;
                    }
                }

                if root.current_page == 0 : VerticalBox {
                    spacing: 16px;
                    vertical-stretch: 1;

                    HorizontalBox {
                        spacing: 12px;

                        MetricTile {
                            label: "Affectations generees";
                            value: "" + root.summary_generated_assignments;
                            helper: "Dans la plage visible.";
                        }
                        MetricTile {
                            label: "Corrections manuelles";
                            value: "" + root.summary_manual_overrides;
                            helper: "Ces corrections passent au-dessus du calcul automatique.";
                        }
                        MetricTile {
                            label: "Equipes actives";
                            value: "" + root.summary_active_teams;
                            helper: "Une equipe active doit couvrir chaque poste du cycle.";
                        }
                        MetricTile {
                            label: "Salaries planifies";
                            value: "" + root.summary_planned_workers;
                            helper: "Membres d'equipe actuellement rattaches.";
                        }
                    }

                    HorizontalBox {
                        spacing: 16px;
                        vertical-stretch: 1;

                        Rectangle {
                            min-width: 360px;
                            preferred-width: 360px;
                            border-radius: 20px;
                            border-width: 1px;
                            border-color: #d7dfd7;
                            background: #f3f6f3;

                            ScrollView {
                                horizontal-stretch: 1;
                                vertical-stretch: 1;

                                VerticalBox {
                                    padding: 16px;
                                    spacing: 16px;

                                    Rectangle {
                                        border-radius: 18px;
                                        border-width: 1px;
                                        border-color: #d7dfd7;
                                        background: #fbfcfb;

                                        VerticalBox {
                                            padding: 14px;
                                            spacing: 10px;

                                            Text {
                                                text: "Generation automatique";
                                                color: #234035;
                                                font-size: 16px;
                                                font-weight: 700;
                                            }

                                            FieldLabel { text: "Date de debut"; }
                                            LineEdit {
                                                text <=> root.planning_start_date;
                                                accessible-label: "Date de debut";
                                            }

                                            FieldLabel { text: "Nombre de jours"; }
                                            LineEdit {
                                                text <=> root.planning_days;
                                                accessible-label: "Nombre de jours";
                                            }

                                            Button {
                                                text: "Generer planning";
                                                enabled: root.can_generate_planning;
                                                clicked => {
                                                    root.generate_planning(root.planning_start_date, root.planning_days);
                                                }
                                            }

                                            Text {
                                                text: "Exemple : 90 pour preparer les 90 prochains jours. Le calcul respecte la rotation hebdomadaire des equipes.";
                                                color: #6b7c72;
                                                font-size: 11px;
                                                wrap: word-wrap;
                                            }
                                        }
                                    }

                                    Rectangle {
                                        border-radius: 18px;
                                        border-width: 1px;
                                        border-color: #d7dfd7;
                                        background: #fbfcfb;

                                        VerticalBox {
                                            padding: 14px;
                                            spacing: 10px;

                                            Text {
                                                text: "Correction manuelle";
                                                color: #234035;
                                                font-size: 16px;
                                                font-weight: 700;
                                            }

                                            Text {
                                                text: root.selected_cell_summary;
                                                color: #6b7c72;
                                                font-size: 11px;
                                                wrap: word-wrap;
                                            }

                                            FieldLabel { text: "Nouvelle plage horaire"; }
                                            manual_shift_combo := ComboBox {
                                                model: root.active_shift_slot_options;
                                                current-index <=> root.manual_shift_index;
                                                accessible-label: "Plage horaire manuelle";
                                            }

                                            Button {
                                                text: "Affecter manuellement";
                                                enabled: root.can_save_manual_assignment;
                                                clicked => {
                                                    root.save_manual_assignment(root.selected_cell_worker_id, root.selected_cell_date, manual_shift_combo.current-index);
                                                }
                                            }

                                            Button {
                                                text: "Marquer sans poste";
                                                enabled: root.has_selected_cell;
                                                clicked => {
                                                    root.mark_manual_off(root.selected_cell_worker_id, root.selected_cell_date);
                                                }
                                            }

                                            Button {
                                                text: "Revenir a l'automatique";
                                                enabled: root.has_selected_cell;
                                                clicked => {
                                                    root.clear_manual_override(root.selected_cell_worker_id, root.selected_cell_date);
                                                }
                                            }

                                            Button {
                                                text: "Effacer la selection";
                                                enabled: root.has_selected_cell;
                                                clicked => { root.clear_planning_selection(); }
                                            }
                                        }
                                    }

                                    Rectangle {
                                        border-radius: 18px;
                                        border-width: 1px;
                                        border-color: #d7dfd7;
                                        background: #fbfcfb;

                                        VerticalBox {
                                            padding: 14px;
                                            spacing: 8px;

                                            Text {
                                                text: "Legende";
                                                color: #234035;
                                                font-size: 16px;
                                                font-weight: 700;
                                            }

                                            Text {
                                                text: "Bordure verte = correction manuelle. OFF = poste retire manuellement.";
                                                color: #6b7c72;
                                                font-size: 11px;
                                                wrap: word-wrap;
                                            }

                                            HorizontalBox {
                                                spacing: 8px;

                                                PlanningShiftCell { cell: { day_offset: 0, short_code: "M", label: "Matin", time_range: "05h00 - 13h00", style_token: "morning-yellow", has_assignment: true, is_manual: false, is_manual_off: false }; }
                                                PlanningShiftCell { cell: { day_offset: 0, short_code: "A", label: "Apres-midi", time_range: "13h00 - 21h00", style_token: "afternoon-red", has_assignment: true, is_manual: false, is_manual_off: false }; }
                                                PlanningShiftCell { cell: { day_offset: 0, short_code: "N", label: "Nuit", time_range: "21h00 - 05h00", style_token: "night-blue", has_assignment: true, is_manual: false, is_manual_off: false }; }
                                                PlanningShiftCell { cell: { day_offset: 0, short_code: "OFF", label: "Sans poste", time_range: "", style_token: "off-gray", has_assignment: false, is_manual: true, is_manual_off: true }; }
                                            }
                                        }
                                    }
                                }
                            }
                        }

                        Rectangle {
                            horizontal-stretch: 1;
                            vertical-stretch: 1;
                            border-radius: 20px;
                            border-width: 1px;
                            border-color: #d7dfd7;
                            background: #f3f6f3;

                            if root.planning_rows.length > 0 : ScrollView {
                                horizontal-stretch: 1;
                                vertical-stretch: 1;

                                VerticalBox {
                                    padding: 14px;
                                    spacing: 6px;

                                    HorizontalBox {
                                        spacing: 6px;

                                        Rectangle {
                                            min-width: 250px;
                                            preferred-width: 250px;
                                            min-height: 62px;
                                            border-radius: 14px;
                                            border-width: 1px;
                                            border-color: #d7dfd7;
                                            background: #e9efe9;

                                            VerticalBox {
                                                alignment: center;
                                                spacing: 2px;

                                                Text {
                                                    text: "Salarie";
                                                    color: #244136;
                                                    font-size: 13px;
                                                    font-weight: 700;
                                                    horizontal-alignment: center;
                                                }

                                                Text {
                                                    text: "Equipe • role • poste";
                                                    color: #6a7c71;
                                                    font-size: 11px;
                                                    horizontal-alignment: center;
                                                }
                                            }
                                        }

                                        for header in root.day_headers : Rectangle {
                                            min-width: 72px;
                                            preferred-width: 72px;
                                            min-height: 62px;
                                            border-radius: 12px;
                                            border-width: 1px;
                                            border-color: header.is_weekend ? #d7c49f : #d7dfd7;
                                            background: header.is_weekend ? #f7efe0 : #fbfcfb;

                                            VerticalBox {
                                                alignment: center;
                                                spacing: 2px;

                                                Text {
                                                    text: header.weekday_label;
                                                    color: #6a7c71;
                                                    font-size: 11px;
                                                    font-weight: 700;
                                                    horizontal-alignment: center;
                                                }

                                                Text {
                                                    text: header.date_label;
                                                    color: #244136;
                                                    font-size: 14px;
                                                    font-weight: 700;
                                                    horizontal-alignment: center;
                                                }

                                                Text {
                                                    text: header.month_label;
                                                    color: #6a7c71;
                                                    font-size: 10px;
                                                    horizontal-alignment: center;
                                                }
                                            }
                                        }
                                    }

                                    for row in root.planning_rows : HorizontalBox {
                                        spacing: 6px;

                                        Rectangle {
                                            min-width: 250px;
                                            preferred-width: 250px;
                                            min-height: 62px;
                                            border-radius: 14px;
                                            border-width: 1px;
                                            border-color: #dde4dd;
                                            background: #fbfcfb;

                                            VerticalBox {
                                                padding: 10px;
                                                spacing: 2px;

                                                Text {
                                                    text: row.worker_name;
                                                    color: #183027;
                                                    font-size: 13px;
                                                    font-weight: 700;
                                                    wrap: word-wrap;
                                                }

                                                Text {
                                                    text: row.team_name + (row.team_role_label != "" ? " • " + row.team_role_label : "");
                                                    color: #4f755d;
                                                    font-size: 11px;
                                                    wrap: word-wrap;
                                                }

                                                Text {
                                                    text: row.job_role_label;
                                                    color: #6b7c72;
                                                    font-size: 11px;
                                                    wrap: word-wrap;
                                                }
                                            }
                                        }

                                        for cell in row.cells : PlanningShiftCell {
                                            cell: cell;
                                            activated(offset) => { root.select_planning_cell(row.worker_id, offset); }
                                        }
                                    }
                                }
                            }

                            if root.planning_rows.length == 0 : Rectangle {
                                background: transparent;
                                VerticalBox {
                                    alignment: center;
                                    spacing: 8px;

                                    Text {
                                        text: "Aucun planning visible.";
                                        color: #244136;
                                        font-size: 18px;
                                        font-weight: 700;
                                    }

                                    Text {
                                        text: "Je genere d'abord une plage de jours, puis le tableau s'affiche ici.";
                                        color: #6b7c72;
                                        font-size: 12px;
                                        wrap: word-wrap;
                                        horizontal-alignment: center;
                                    }
                                }
                            }
                        }
                    }
                }

                if root.current_page == 1 : HorizontalBox {
                    spacing: 16px;
                    vertical-stretch: 1;

                    Rectangle {
                        min-width: 340px;
                        preferred-width: 340px;
                        border-radius: 20px;
                        border-width: 1px;
                        border-color: #d7dfd7;
                        background: #f3f6f3;

                        VerticalBox {
                            padding: 16px;
                            spacing: 12px;

                            HorizontalBox {
                                spacing: 8px;
                                Text {
                                    text: "Equipes";
                                    color: #234035;
                                    font-size: 18px;
                                    font-weight: 700;
                                }
                                Rectangle { horizontal-stretch: 1; background: transparent; }
                                Button {
                                    text: "Nouvelle equipe";
                                    clicked => { root.clear_team_form(); }
                                }
                            }

                            if root.team_rows.length > 0 : ScrollView {
                                horizontal-stretch: 1;
                                vertical-stretch: 1;

                                VerticalBox {
                                    spacing: 8px;

                                    for team in root.team_rows : TeamListItem {
                                        team_row: team;
                                        selected: root.team_form_id == team.id;
                                        activated(team_id) => { root.select_team(team_id); }
                                    }
                                }
                            }

                            if root.team_rows.length == 0 : Rectangle {
                                vertical-stretch: 1;
                                background: transparent;
                                Text {
                                    text: "Aucune equipe.";
                                    color: #6b7c72;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }

                    Rectangle {
                        horizontal-stretch: 1;
                        border-radius: 20px;
                        border-width: 1px;
                        border-color: #d7dfd7;
                        background: #f3f6f3;

                        ScrollView {
                            horizontal-stretch: 1;
                            vertical-stretch: 1;

                            VerticalBox {
                                padding: 16px;
                                spacing: 16px;

                                Rectangle {
                                    border-radius: 18px;
                                    border-width: 1px;
                                    border-color: #d7dfd7;
                                    background: #fbfcfb;

                                    VerticalBox {
                                        padding: 14px;
                                        spacing: 10px;

                                        Text {
                                            text: root.team_existing ? "Modifier une equipe" : "Nouvelle equipe";
                                            color: #234035;
                                            font-size: 16px;
                                            font-weight: 700;
                                        }

                                        FieldLabel { text: "Nom de l'equipe"; }
                                        LineEdit {
                                            text <=> root.team_name;
                                            accessible-label: "Nom de l'equipe";
                                        }

                                        FieldLabel { text: "Poste de reference sur la semaine de depart"; }
                                        ComboBox {
                                            model: root.active_shift_slot_options;
                                            current-index <=> root.team_anchor_shift_index;
                                            accessible-label: "Poste de reference";
                                        }

                                        FieldLabel { text: "Etat"; }
                                        ComboBox {
                                            model: root.active_state_options;
                                            current-index <=> root.team_active_index;
                                            accessible-label: "Etat de l'equipe";
                                        }

                                        HorizontalBox {
                                            spacing: 8px;

                                            Button {
                                                text: "Enregistrer l'equipe";
                                                enabled: root.can_save_team;
                                                clicked => {
                                                    root.save_team(root.team_form_id, root.team_name, root.team_anchor_shift_index, root.team_active_index);
                                                }
                                            }

                                            Button {
                                                text: "Vider le formulaire";
                                                clicked => { root.clear_team_form(); }
                                            }
                                        }
                                    }
                                }

                                Rectangle {
                                    border-radius: 18px;
                                    border-width: 1px;
                                    border-color: #d7dfd7;
                                    background: #fbfcfb;

                                    VerticalBox {
                                        padding: 14px;
                                        spacing: 10px;

                                        Text {
                                            text: "Membres de l'equipe";
                                            color: #234035;
                                            font-size: 16px;
                                            font-weight: 700;
                                        }

                                        Text {
                                            text: root.team_form_id == "" ? "Je selectionne d'abord une equipe pour gerer ses membres." : "Je conserve un seul chef d'equipe et un ou plusieurs operateurs.";
                                            color: #6b7c72;
                                            font-size: 11px;
                                            wrap: word-wrap;
                                        }

                                        FieldLabel { text: "Salarie"; }
                                        team_member_worker_combo := ComboBox {
                                            model: root.team_member_candidate_options;
                                            current-index <=> root.team_member_worker_index;
                                            enabled: root.team_form_id != "";
                                            accessible-label: "Salarie a ajouter";
                                        }

                                        FieldLabel { text: "Role dans l'equipe"; }
                                        ComboBox {
                                            model: root.team_member_role_options;
                                            current-index <=> root.team_member_role_index;
                                            enabled: root.team_form_id != "";
                                            accessible-label: "Role dans l'equipe";
                                        }

                                        Button {
                                            text: "Ajouter le membre";
                                            enabled: root.can_add_team_member;
                                            clicked => {
                                                root.add_team_member(root.team_form_id, team_member_worker_combo.current-index, root.team_member_role_index);
                                            }
                                        }

                                        if root.selected_team_member_rows.length > 0 : VerticalBox {
                                            spacing: 8px;

                                            for member in root.selected_team_member_rows : TeamMemberListItem {
                                                member_row: member;
                                                remove(worker_id) => { root.remove_team_member(root.team_form_id, worker_id); }
                                            }
                                        }

                                        if root.selected_team_member_rows.length == 0 : Rectangle {
                                            min-height: 52px;
                                            border-radius: 12px;
                                            border-width: 1px;
                                            border-color: #dde5dd;
                                            background: #f8faf8;

                                            Text {
                                                text: "Aucun membre sur cette equipe.";
                                                color: #6b7c72;
                                                vertical-alignment: center;
                                                horizontal-alignment: center;
                                                width: parent.width;
                                                height: parent.height;
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }

                if root.current_page == 2 : HorizontalBox {
                    spacing: 16px;
                    vertical-stretch: 1;

                    Rectangle {
                        min-width: 340px;
                        preferred-width: 340px;
                        border-radius: 20px;
                        border-width: 1px;
                        border-color: #d7dfd7;
                        background: #f3f6f3;

                        VerticalBox {
                            padding: 16px;
                            spacing: 12px;

                            HorizontalBox {
                                spacing: 8px;
                                Text {
                                    text: "Plages horaires";
                                    color: #234035;
                                    font-size: 18px;
                                    font-weight: 700;
                                }
                                Rectangle { horizontal-stretch: 1; background: transparent; }
                                Button {
                                    text: "Nouvelle plage";
                                    clicked => { root.clear_shift_slot_form(); }
                                }
                            }

                            if root.shift_slot_rows.length > 0 : ScrollView {
                                horizontal-stretch: 1;
                                vertical-stretch: 1;

                                VerticalBox {
                                    spacing: 8px;

                                    for slot in root.shift_slot_rows : ShiftSlotListItem {
                                        shift_slot_row: slot;
                                        selected: root.shift_slot_form_id == slot.id;
                                        activated(slot_id) => { root.select_shift_slot(slot_id); }
                                    }
                                }
                            }

                            if root.shift_slot_rows.length == 0 : Rectangle {
                                vertical-stretch: 1;
                                background: transparent;
                                Text {
                                    text: "Aucune plage horaire.";
                                    color: #6b7c72;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }

                    Rectangle {
                        horizontal-stretch: 1;
                        border-radius: 20px;
                        border-width: 1px;
                        border-color: #d7dfd7;
                        background: #f3f6f3;

                        ScrollView {
                            horizontal-stretch: 1;
                            vertical-stretch: 1;

                            VerticalBox {
                                padding: 16px;
                                spacing: 16px;

                                Rectangle {
                                    border-radius: 18px;
                                    border-width: 1px;
                                    border-color: #d7dfd7;
                                    background: #fbfcfb;

                                    VerticalBox {
                                        padding: 14px;
                                        spacing: 10px;

                                        Text {
                                            text: root.shift_slot_existing ? "Modifier une plage horaire" : "Nouvelle plage horaire";
                                            color: #234035;
                                            font-size: 16px;
                                            font-weight: 700;
                                        }

                                        FieldLabel { text: "Nom"; }
                                        LineEdit { text <=> root.shift_slot_name; accessible-label: "Nom de la plage"; }

                                        FieldLabel { text: "Code court"; }
                                        LineEdit { text <=> root.shift_slot_code; accessible-label: "Code court"; }

                                        HorizontalBox {
                                            spacing: 12px;

                                            VerticalBox {
                                                spacing: 6px;
                                                horizontal-stretch: 1;
                                                FieldLabel { text: "Debut (heure)"; }
                                                LineEdit { text <=> root.shift_slot_start_hour; accessible-label: "Heure de debut"; }
                                            }

                                            VerticalBox {
                                                spacing: 6px;
                                                horizontal-stretch: 1;
                                                FieldLabel { text: "Debut (minute)"; }
                                                LineEdit { text <=> root.shift_slot_start_minute; accessible-label: "Minute de debut"; }
                                            }
                                        }

                                        HorizontalBox {
                                            spacing: 12px;

                                            VerticalBox {
                                                spacing: 6px;
                                                horizontal-stretch: 1;
                                                FieldLabel { text: "Fin (heure)"; }
                                                LineEdit { text <=> root.shift_slot_end_hour; accessible-label: "Heure de fin"; }
                                            }

                                            VerticalBox {
                                                spacing: 6px;
                                                horizontal-stretch: 1;
                                                FieldLabel { text: "Fin (minute)"; }
                                                LineEdit { text <=> root.shift_slot_end_minute; accessible-label: "Minute de fin"; }
                                            }
                                        }

                                        FieldLabel { text: "Style visuel"; }
                                        ComboBox {
                                            model: root.shift_style_options;
                                            current-index <=> root.shift_slot_style_index;
                                            accessible-label: "Style visuel";
                                        }

                                        FieldLabel { text: "Etat"; }
                                        ComboBox {
                                            model: root.active_state_options;
                                            current-index <=> root.shift_slot_active_index;
                                            accessible-label: "Etat de la plage";
                                        }

                                        HorizontalBox {
                                            spacing: 8px;

                                            Button {
                                                text: "Enregistrer la plage";
                                                enabled: root.can_save_shift_slot;
                                                clicked => {
                                                    root.save_shift_slot(
                                                        root.shift_slot_form_id,
                                                        root.shift_slot_name,
                                                        root.shift_slot_code,
                                                        root.shift_slot_start_hour,
                                                        root.shift_slot_start_minute,
                                                        root.shift_slot_end_hour,
                                                        root.shift_slot_end_minute,
                                                        root.shift_slot_style_index,
                                                        root.shift_slot_active_index
                                                    );
                                                }
                                            }

                                            Button {
                                                text: "Vider le formulaire";
                                                clicked => { root.clear_shift_slot_form(); }
                                            }
                                        }
                                    }
                                }

                                Rectangle {
                                    border-radius: 18px;
                                    border-width: 1px;
                                    border-color: #d7dfd7;
                                    background: #fbfcfb;

                                    VerticalBox {
                                        padding: 14px;
                                        spacing: 10px;

                                        Text {
                                            text: "Cycle hebdomadaire 3x8";
                                            color: #234035;
                                            font-size: 16px;
                                            font-weight: 700;
                                        }

                                        Text {
                                            text: "Je definis la semaine de reference puis l'ordre des 3 postes qui tournent de semaine en semaine.";
                                            color: #6b7c72;
                                            font-size: 11px;
                                            wrap: word-wrap;
                                        }

                                        FieldLabel { text: "Debut de semaine de reference (lundi)"; }
                                        LineEdit { text <=> root.rotation_reference_week_start; accessible-label: "Debut de semaine de reference"; }

                                        FieldLabel { text: "Semaine 1"; }
                                        ComboBox {
                                            model: root.active_shift_slot_options;
                                            current-index <=> root.rotation_week_one_shift_index;
                                            accessible-label: "Semaine 1";
                                        }

                                        FieldLabel { text: "Semaine 2"; }
                                        ComboBox {
                                            model: root.active_shift_slot_options;
                                            current-index <=> root.rotation_week_two_shift_index;
                                            accessible-label: "Semaine 2";
                                        }

                                        FieldLabel { text: "Semaine 3"; }
                                        ComboBox {
                                            model: root.active_shift_slot_options;
                                            current-index <=> root.rotation_week_three_shift_index;
                                            accessible-label: "Semaine 3";
                                        }

                                        Button {
                                            text: "Enregistrer le cycle";
                                            clicked => {
                                                root.save_rotation_cycle(
                                                    root.rotation_reference_week_start,
                                                    root.rotation_week_one_shift_index,
                                                    root.rotation_week_two_shift_index,
                                                    root.rotation_week_three_shift_index
                                                );
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }

                if root.current_page == 3 : HorizontalBox {
                    spacing: 16px;
                    vertical-stretch: 1;

                    Rectangle {
                        min-width: 340px;
                        preferred-width: 340px;
                        border-radius: 20px;
                        border-width: 1px;
                        border-color: #d7dfd7;
                        background: #f3f6f3;

                        VerticalBox {
                            padding: 16px;
                            spacing: 12px;

                            HorizontalBox {
                                spacing: 8px;
                                Text {
                                    text: "Salaries";
                                    color: #234035;
                                    font-size: 18px;
                                    font-weight: 700;
                                }
                                Rectangle { horizontal-stretch: 1; background: transparent; }
                                Button {
                                    text: "Nouvelle fiche";
                                    clicked => { root.clear_worker_form(); }
                                }
                            }

                            if root.worker_rows.length > 0 : ScrollView {
                                horizontal-stretch: 1;
                                vertical-stretch: 1;

                                VerticalBox {
                                    spacing: 8px;

                                    for worker in root.worker_rows : WorkerListItem {
                                        worker_row: worker;
                                        selected: root.worker_form_id == worker.id;
                                        activated(worker_id) => { root.select_worker(worker_id); }
                                    }
                                }
                            }

                            if root.worker_rows.length == 0 : Rectangle {
                                vertical-stretch: 1;
                                background: transparent;
                                Text {
                                    text: "Aucun salarie.";
                                    color: #6b7c72;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }

                    Rectangle {
                        horizontal-stretch: 1;
                        border-radius: 20px;
                        border-width: 1px;
                        border-color: #d7dfd7;
                        background: #f3f6f3;

                        ScrollView {
                            horizontal-stretch: 1;
                            vertical-stretch: 1;

                            VerticalBox {
                                padding: 16px;
                                spacing: 16px;

                                Rectangle {
                                    border-radius: 18px;
                                    border-width: 1px;
                                    border-color: #d7dfd7;
                                    background: #fbfcfb;

                                    VerticalBox {
                                        padding: 14px;
                                        spacing: 10px;

                                        Text {
                                            text: root.worker_existing ? "Modifier une fiche" : "Nouvelle fiche";
                                            color: #234035;
                                            font-size: 16px;
                                            font-weight: 700;
                                        }

                                        if root.worker_existing : Text {
                                            text: "Identifiant interne : " + root.worker_form_id;
                                            color: #6b7c72;
                                            font-size: 11px;
                                        }

                                        FieldLabel { text: "Nom"; }
                                        LineEdit { text <=> root.worker_last_name; accessible-label: "Nom"; }

                                        FieldLabel { text: "Prenom"; }
                                        LineEdit { text <=> root.worker_first_name; accessible-label: "Prenom"; }

                                        FieldLabel { text: "Poste"; }
                                        ComboBox {
                                            model: root.role_options;
                                            current-index <=> root.worker_role_index;
                                            accessible-label: "Poste";
                                        }

                                        HorizontalBox {
                                            spacing: 8px;

                                            Button {
                                                text: "Enregistrer la fiche";
                                                enabled: root.can_save_worker;
                                                clicked => {
                                                    root.save_worker(root.worker_form_id, root.worker_last_name, root.worker_first_name, root.worker_role_index);
                                                }
                                            }

                                            Button {
                                                text: "Supprimer";
                                                enabled: root.worker_existing;
                                                clicked => { root.delete_worker(root.worker_form_id); }
                                            }

                                            Button {
                                                text: "Vider le formulaire";
                                                clicked => { root.clear_worker_form(); }
                                            }
                                        }
                                    }
                                }

                                Rectangle {
                                    border-radius: 18px;
                                    border-width: 1px;
                                    border-color: #d7dfd7;
                                    background: #fbfcfb;

                                    VerticalBox {
                                        padding: 14px;
                                        spacing: 10px;

                                        Text {
                                            text: "Catalogue des postes";
                                            color: #234035;
                                            font-size: 16px;
                                            font-weight: 700;
                                        }

                                        FieldLabel { text: "Ajouter un nouveau poste"; }
                                        HorizontalBox {
                                            spacing: 8px;

                                            LineEdit {
                                                horizontal-stretch: 1;
                                                text <=> root.new_role_name;
                                                accessible-label: "Nouveau poste";
                                            }

                                            Button {
                                                text: "Ajouter";
                                                enabled: root.can_add_job_role;
                                                clicked => { root.add_job_role(root.new_role_name); }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
