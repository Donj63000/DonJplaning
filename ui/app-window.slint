
import { Button, ComboBox, HorizontalBox, LineEdit, ScrollView, VerticalBox } from "std-widgets.slint";

export struct WorkerRowData {
    id: string,
    display_name: string,
    job_role_label: string,
    team_name: string,
}

export struct ShiftSlotRowData {
    id: string,
    name: string,
    short_code: string,
    time_range: string,
    style_label: string,
    active_label: string,
}

export struct TeamRowData {
    id: string,
    name: string,
    anchor_shift_label: string,
    member_count: int,
    leader_name: string,
    active_label: string,
}

export struct TeamMemberRowData {
    worker_id: string,
    worker_name: string,
    role_label: string,
}

export struct DayHeaderData {
    day_offset: int,
    date_label: string,
    weekday_label: string,
    month_label: string,
    is_weekend: bool,
}

export struct PlanningCellData {
    day_offset: int,
    short_code: string,
    label: string,
    time_range: string,
    style_token: string,
    has_assignment: bool,
    is_manual: bool,
    is_manual_off: bool,
}

export struct PlanningRowData {
    worker_id: string,
    worker_name: string,
    team_name: string,
    team_role_label: string,
    job_role_label: string,
    cells: [PlanningCellData],
}

component SidebarButton inherits FocusScope {
    in property <string> label;
    in property <bool> active;
    callback clicked;

    min-height: 46px;
    accessible-role: button;
    accessible-label: label;
    accessible-action-default => { root.clicked(); }

    Rectangle {
        border-radius: 14px;
        border-width: root.has-focus ? 2px : 1px;
        border-color: root.has-focus ? #264538 : (root.active ? #4f755d : #d6dfd6);
        background: root.active ? (area.has-hover ? #456a53 : #4f755d) : (area.has-hover ? #edf3ee : #f7f9f7);
        width: parent.width;
        height: parent.height;

        Text {
            text: root.label;
            color: root.active ? white : #21352b;
            font-weight: 700;
            horizontal-alignment: center;
            vertical-alignment: center;
            width: parent.width;
            height: parent.height;
        }
    }

    area := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.focus();
            root.clicked();
        }
    }
}

component FieldLabel inherits Text {
    color: #3f584d;
    font-size: 12px;
    font-weight: 700;
}

component MetricTile inherits Rectangle {
    in property <string> label;
    in property <string> value;
    in property <string> helper;

    min-width: 168px;
    preferred-width: 168px;
    min-height: 92px;
    border-radius: 18px;
    border-width: 1px;
    border-color: #d6dfd6;
    background: #fbfcfb;

    VerticalBox {
        padding: 14px;
        spacing: 4px;

        Text {
            text: root.label;
            color: #6a7c71;
            font-size: 11px;
            font-weight: 700;
        }

        Text {
            text: root.value;
            color: #183027;
            font-size: 24px;
            font-weight: 700;
        }

        if root.helper != "" : Text {
            text: root.helper;
            color: #738378;
            font-size: 11px;
            wrap: word-wrap;
        }
    }
}

component WorkerListItem inherits FocusScope {
    in property <WorkerRowData> worker_row;
    in property <bool> selected;
    callback activated(string);

    min-height: 74px;
    accessible-role: button;
    accessible-label: root.worker_row.display_name;
    accessible-description: root.worker_row.job_role_label;
    accessible-action-default => { root.activated(root.worker_row.id); }

    Rectangle {
        border-radius: 14px;
        border-width: root.has-focus ? 2px : 1px;
        border-color: root.has-focus ? #264538 : (root.selected ? #7ea08a : #dde5dd);
        background: root.selected ? #e3eee6 : (area.has-hover ? #f4f7f4 : #fbfcfb);
        width: parent.width;
        height: parent.height;

        HorizontalBox {
            padding: 12px;
            spacing: 12px;

            Rectangle {
                min-width: 4px;
                max-width: 4px;
                border-radius: 2px;
                background: root.selected ? #4f755d : transparent;
            }

            VerticalBox {
                alignment: center;
                spacing: 2px;
                horizontal-stretch: 1;

                Text {
                    text: root.worker_row.display_name;
                    color: #183027;
                    font-size: 13px;
                    font-weight: 700;
                    wrap: word-wrap;
                }

                Text {
                    text: root.worker_row.job_role_label;
                    color: #6b7c72;
                    font-size: 11px;
                    wrap: word-wrap;
                }

                if root.worker_row.team_name != "" : Text {
                    text: root.worker_row.team_name;
                    color: #4f755d;
                    font-size: 11px;
                    wrap: word-wrap;
                }
            }
        }
    }

    area := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.focus();
            root.activated(root.worker_row.id);
        }
    }
}

component ShiftSlotListItem inherits FocusScope {
    in property <ShiftSlotRowData> shift_slot_row;
    in property <bool> selected;
    callback activated(string);

    min-height: 78px;
    accessible-role: button;
    accessible-label: root.shift_slot_row.name;
    accessible-description: root.shift_slot_row.time_range;
    accessible-action-default => { root.activated(root.shift_slot_row.id); }

    Rectangle {
        border-radius: 14px;
        border-width: root.has-focus ? 2px : 1px;
        border-color: root.has-focus ? #264538 : (root.selected ? #7ea08a : #dde5dd);
        background: root.selected ? #e3eee6 : (area.has-hover ? #f4f7f4 : #fbfcfb);
        width: parent.width;
        height: parent.height;

        HorizontalBox {
            padding: 12px;
            spacing: 12px;

            Rectangle {
                min-width: 42px;
                max-width: 42px;
                min-height: 42px;
                max-height: 42px;
                border-radius: 12px;
                background: #edf2ee;

                Text {
                    text: root.shift_slot_row.short_code;
                    color: #244136;
                    font-size: 16px;
                    font-weight: 700;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    width: parent.width;
                    height: parent.height;
                }
            }

            VerticalBox {
                alignment: center;
                spacing: 2px;
                horizontal-stretch: 1;

                Text {
                    text: root.shift_slot_row.name;
                    color: #183027;
                    font-size: 13px;
                    font-weight: 700;
                    wrap: word-wrap;
                }

                Text {
                    text: root.shift_slot_row.time_range;
                    color: #6b7c72;
                    font-size: 11px;
                }

                Text {
                    text: root.shift_slot_row.style_label + " • " + root.shift_slot_row.active_label;
                    color: #4f755d;
                    font-size: 11px;
                    wrap: word-wrap;
                }
            }
        }
    }

    area := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.focus();
            root.activated(root.shift_slot_row.id);
        }
    }
}

component TeamListItem inherits FocusScope {
    in property <TeamRowData> team_row;
    in property <bool> selected;
    callback activated(string);

    min-height: 82px;
    accessible-role: button;
    accessible-label: root.team_row.name;
    accessible-description: root.team_row.anchor_shift_label;
    accessible-action-default => { root.activated(root.team_row.id); }

    Rectangle {
        border-radius: 14px;
        border-width: root.has-focus ? 2px : 1px;
        border-color: root.has-focus ? #264538 : (root.selected ? #7ea08a : #dde5dd);
        background: root.selected ? #e3eee6 : (area.has-hover ? #f4f7f4 : #fbfcfb);
        width: parent.width;
        height: parent.height;

        VerticalBox {
            padding: 12px;
            spacing: 2px;

            Text {
                text: root.team_row.name;
                color: #183027;
                font-size: 13px;
                font-weight: 700;
            }

            Text {
                text: "Reference: " + root.team_row.anchor_shift_label;
                color: #6b7c72;
